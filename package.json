{
  "name": "langflow-native",
  "version": "0.1.0",
  "description": "A React Native framework for running Langflow workflows on-device",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -pt run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint packages --ext .ts,.tsx",
    "lint:fix": "eslint packages --ext .ts,.tsx --fix",
    "typecheck": "yarn workspaces foreach -pt run typecheck",
    "clean": "yarn workspaces foreach -pt run clean",
    "format": "prettier --write \"packages/**/src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"packages/**/src/**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/jest": "^29.5.0",
    "typescript": "^5.3.0",
    "prettier": "^3.1.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "yarn": ">=1.22.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/langflow-native.git"
  },
  "keywords": [
    "langflow",
    "react-native",
    "ai",
    "llm",
    "workflow",
    "langchain",
    "mobile"
  ],
  "author": "Langflow Native Contributors",
  "license": "MIT"
}

